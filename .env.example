# ─── Telegram ───────────────────────────────
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
CHAT_ID=YOUR_CHAT_ID_HERE

# ─── Validator ──────────────────────────────
VALIDATOR_ADDR=raivaloper1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WALLET_ADDR=rai1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONIKER=MyValidator

# ─── Admin (virgülle ayır / comma separated) ─
# Boş bırakırsan herkes kullanabilir
# Leave empty to allow all users
ADMIN_IDS=

# ─── Endpoints ──────────────────────────────
RPC_URL=https://rpc.republicai.io
REST_URL=https://rest.republicai.io

# ─── Alert Intervals (saniye / seconds) ─────
GOVERNANCE_CHECK_INTERVAL=60
VALIDATOR_CHECK_INTERVAL=120
ACTIVE_SET_CHECK_INTERVAL=300

# ─── Alert Thresholds ───────────────────────
UPTIME_ALERT_THRESHOLD=95.0
ACTIVE_SET_MARGIN_PERCENT=5.0
